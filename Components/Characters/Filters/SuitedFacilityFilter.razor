@inherits BaseFilterComponent

@code
{
    [Parameter]
    [EditorRequired]
    public required SuitedFacility SuitedFacility { get; set; }

    protected override void OnInitialized()
    {
        Filter ??= new Filter($"{nameof(SuitedFacility)}_{SuitedFacility.FieldBuilding.Name}_{SuitedFacility.Value}", GetType(), SuitedFacility, unit =>
        {
            return unit.SuitedFacilities.Index().Any(tuple =>
                (tuple.Index == 0 ? SuitedFacility.Value is 200 or 30 : SuitedFacility.Value is 100 or 10) &&
                tuple.Item.Equals(SuitedFacility.FieldBuilding.Name, StringComparison.OrdinalIgnoreCase));
        });

        base.OnInitialized();
    }
}

<FilterComponent IsRemoveMode="IsRemoveMode" OnClick="Execute">
    <ImageProxy Source="@SuitedFacility.FieldBuilding.Icon" Width="Width.Em(2)" Height="Height.Em(2)"
                Text="@SuitedFacility.FieldBuilding.Name"/>
    <Text>@SuitedFacility.FieldBuilding.Name (@SuitedFacility.Value%)</Text>
</FilterComponent>