@inherits BaseFilterComponent

@code
{
    [Parameter]
    [EditorRequired]
    public required SuitedFacility SuitedFacility { get; set; }

    protected override void OnInitialized()
    {
        Filter ??= new Filter(
            $"{nameof(SuitedFacility)}_{SuitedFacility.FieldBuilding.Name}_{SuitedFacility.Value}",
            GetType(),
            SuitedFacility,
            unit =>
                (unit.SuitedFacilityOneName.Equals(SuitedFacility.FieldBuilding.Name, StringComparison.OrdinalIgnoreCase) && unit.SuitedFacilityOneRate == SuitedFacility.Value) ||
                (unit.SuitedFacilityTwoName is not null && unit.SuitedFacilityTwoName.Equals(SuitedFacility.FieldBuilding.Name, StringComparison.OrdinalIgnoreCase) && unit.SuitedFacilityTwoRate == SuitedFacility.Value)
        );

        base.OnInitialized();
    }
}

<FilterComponent IsRemoveMode="IsRemoveMode" OnClick="Execute">
    <ImageProxy Source="@SuitedFacility.FieldBuilding.Icon" Width="Width.Em(2)" Height="Height.Em(2)"
                Text="@SuitedFacility.FieldBuilding.Name"/>
    <Text>@SuitedFacility.FieldBuilding.Name (@SuitedFacility.Value%)</Text>
</FilterComponent>