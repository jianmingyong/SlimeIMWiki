@using SlimeIMWiki.Models.JsonData
@inherits BaseFilterComponent

@code
{
    [Parameter]
    [EditorRequired]
    public required Force Force { get; set; }

    protected override void OnInitialized()
    {
        Filter ??= new Filter($"{nameof(Force)}_{Force.Name}", GetType(), Force, unit =>
        {
            return unit switch
            {
                BattleUnitData battleUnit => battleUnit.Forces.Any(force => force.Equals(Force.Name, StringComparison.OrdinalIgnoreCase)),
                ProtectionUnitData protectionUnit => protectionUnit.Forces?.Any(force => force.Equals(Force.Name, StringComparison.OrdinalIgnoreCase)) ?? false,
                var _ => false
            };
        });

        base.OnInitialized();
    }
}

<FilterComponent IsRemoveMode="IsRemoveMode" OnClick="Execute">
    <ImageProxy Source="@Force.Icon" Width="Width.Em(2)" Text="@Force.Name"/>
    <Text>@Force.Name</Text>
</FilterComponent>