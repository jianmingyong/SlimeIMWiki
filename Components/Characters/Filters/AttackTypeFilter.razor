@using SlimeIMWiki.Models.JsonData
@inherits BaseFilterComponent

@code
{
    [Parameter]
    [EditorRequired]
    public required IAttackType AttackType { get; set; }

    protected override void OnInitialized()
    {
        Filter ??= new Filter($"{nameof(AttackType)}_{AttackType.Name}", GetType(), AttackType, unit =>
        {
            return unit switch
            {
                BattleUnitData battleUnit => battleUnit.AttackType.Equals(AttackType.Name, StringComparison.OrdinalIgnoreCase),
                ProtectionUnitData protectionUnit => protectionUnit.AttackType?.Equals(AttackType.Name, StringComparison.OrdinalIgnoreCase) ?? false,
                var _ => false
            };
        });

        base.OnInitialized();
    }
}

<FilterComponent DisplayText="@AttackType.Name" IsRemoveMode="IsRemoveMode" OnClick="Execute">
    <ImageProxy Class="filterIcon" Source="@AttackType.Icon" Width="Width.Em(1.5)" Height="Height.Em(1.5)"/>
</FilterComponent>