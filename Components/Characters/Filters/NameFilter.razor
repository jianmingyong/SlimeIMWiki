@using SlimeIMWiki.Models.JsonData
@inherits BaseFilterComponent

@code
{
    [Parameter]
    [EditorRequired]
    public required SearchResult Search { get; set; }

    protected override void OnInitialized()
    {
        Filter ??= new Filter($"{nameof(Search)}_{Search.DisplayValue}", GetType(), Search, unit =>
        {
            return unit switch
            {
                BattleUnitData battleUnit => Search.SearchType switch
                {
                    SearchResultType.Name => battleUnit.Name.Equals(Search.SearchValue, StringComparison.OrdinalIgnoreCase),
                    SearchResultType.Title => battleUnit.Title.Equals(Search.SearchValue, StringComparison.OrdinalIgnoreCase),
                    var _ => false
                },
                ProtectionUnitData protectionUnit => Search.SearchType switch
                {
                    SearchResultType.Name => protectionUnit.Name.Equals(Search.SearchValue, StringComparison.OrdinalIgnoreCase),
                    SearchResultType.Title => protectionUnit.Title.Equals(Search.SearchValue, StringComparison.OrdinalIgnoreCase),
                    var _ => false
                },
                var _ => false
            };
        });

        base.OnInitialized();
    }
}

<FilterComponent IsRemoveMode="IsRemoveMode" OnClick="Execute">
    <Text>@Search.DisplayValue</Text>
</FilterComponent>