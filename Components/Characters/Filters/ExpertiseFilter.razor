@using SlimeIMWiki.Models.JsonData
@inherits BaseFilterComponent

<FilterComponent DisplayText="@Expertise.Name" IsRemoveMode="IsRemoveMode" OnClick="Execute">
    <ImageProxy Class="filterIcon" Source="@Expertise.Icon" Width="Width.Em(1.5)" Height="Height.Em(1.5)"/>
</FilterComponent>

@code
{
    [Parameter]
    [EditorRequired]
    public required BattleExpertise Expertise { get; set; }

    protected override void OnInitialized()
    {
        Filter ??= new Filter($"{nameof(Expertise)}_{Expertise.Name}", GetType(), Expertise, unit =>
        {
            return unit switch
            {
                BattleUnitData battleUnit => battleUnit.Expertise.Equals(Expertise.Name, StringComparison.OrdinalIgnoreCase),
                var _ => false
            };
        });

        base.OnInitialized();
    }
}