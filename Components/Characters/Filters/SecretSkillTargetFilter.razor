@using SlimeIMWiki.Models.JsonData
@inherits BaseFilterComponent

@code
{
    [Parameter]
    [EditorRequired]
    public required string SecretSkillTarget { get; set; }

    protected override void OnInitialized()
    {
        Filter ??= new Filter($"{nameof(SecretSkillTarget)}_{SecretSkillTarget}", GetType(), SecretSkillTarget, unit =>
        {
            return unit switch
            {
                BattleUnitData battleUnit => battleUnit.SecretSkillTarget.Equals(SecretSkillTarget, StringComparison.OrdinalIgnoreCase),
                var _ => false
            };
        });

        base.OnInitialized();
    }
}

<FilterComponent DisplayText="@SecretSkillTarget" IsRemoveMode="IsRemoveMode" OnClick="Execute">
    <ImageProxy Class="filterIcon" Source="@($"image/character_info/icSpType{SecretSkillTarget}.png")"
                Height="Height.Em(1.5)"/>
</FilterComponent>