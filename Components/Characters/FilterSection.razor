@using System.Reactive.Disposables.Fluent
@using DynamicData.Binding
@using ReactiveUI
@using SlimeIMWiki.Components.Characters.Filters
@using SlimeIMWiki.Models.JsonData
@inherits ReactiveComponentBase<FilterSectionViewModel>

@inject IServiceProvider ServiceProvider

@code
{
    protected override void OnInitialized()
    {
        ViewModel = ActivatorUtilities.CreateInstance<FilterSectionViewModel>(ServiceProvider);

        this.WhenActivated(disposable =>
        {
#pragma warning disable CS8602 // Dereference of a possibly null reference.
            this.WhenAnyValue(section => section.ViewModel.AttackTypes)
#pragma warning restore CS8602 // Dereference of a possibly null reference.
                .SwitchSelect(types => types.ObserveCollectionChanges())
                .Subscribe(_ => InvokeAsync(StateHasChanged))
                .DisposeWith(disposable);

#pragma warning disable CS8602 // Dereference of a possibly null reference.
            this.WhenAnyValue(section => section.ViewModel.Attributes)
#pragma warning restore CS8602 // Dereference of a possibly null reference.
                .SwitchSelect(attributes => attributes.ObserveCollectionChanges())
                .Subscribe(_ => InvokeAsync(StateHasChanged))
                .DisposeWith(disposable);

#pragma warning disable CS8602 // Dereference of a possibly null reference.
            this.WhenAnyValue(section => section.ViewModel.BattleExpertises)
#pragma warning restore CS8602 // Dereference of a possibly null reference.
                .SwitchSelect(expertises => expertises.ObserveCollectionChanges())
                .Subscribe(_ => InvokeAsync(StateHasChanged))
                .DisposeWith(disposable);

#pragma warning disable CS8602 // Dereference of a possibly null reference.
            this.WhenAnyValue(section => section.ViewModel.Forces)
#pragma warning restore CS8602 // Dereference of a possibly null reference.
                .SwitchSelect(forces => forces.ObserveCollectionChanges())
                .Subscribe(_ => InvokeAsync(StateHasChanged))
                .DisposeWith(disposable);

#pragma warning disable CS8602 // Dereference of a possibly null reference.
            this.WhenAnyValue(section => section.ViewModel.SuitedFacilities)
#pragma warning restore CS8602 // Dereference of a possibly null reference.
                .SwitchSelect(buildings => buildings.ObserveCollectionChanges())
                .Subscribe(_ => InvokeAsync(StateHasChanged))
                .DisposeWith(disposable);

#pragma warning disable CS8602 // Dereference of a possibly null reference.
            this.WhenAnyValue(section => section.ViewModel.Filters)
#pragma warning restore CS8602 // Dereference of a possibly null reference.
                .SwitchSelect(filters => filters.ObserveCollectionChanges())
                .Subscribe(_ => InvokeAsync(StateHasChanged))
                .DisposeWith(disposable);
        });

        base.OnInitialized();
    }
}

@{ Debug.Assert(ViewModel != null, nameof(ViewModel) + " != null"); }

<Div Flex="Flex.Wrap" Width="Width.Is100" Margin="Margin.Is2.FromBottom" Gap="Gap.Is2">
    <Div Flex="Flex.Row.JustifyContent.Start.AlignItems.Center.Grow.Is1" Gap="Gap.Is2">
        <Icon Name="IconName.Search" IconSize="IconSize.Default"/>
        <Autocomplete
            TItem="SearchResult" TValue="SearchResult"
            TextField="s => s.DisplayValue" ValueField="s => s"
            Data="ViewModel.SearchResults"
            ReadData="ViewModel.AutoCompleteCallback"
            Placeholder="Search..." FreeTyping="true"
            Debounce="true" DebounceInterval="250"
            SelectedValueChanged="ViewModel.SelectedValueChangedCallback">
        </Autocomplete>
    </Div>

    <Div Flex="Flex.JustifyContent.End.OnTablet.AlignItems.Center.Grow.Is1">
        <Switch TValue="bool" @bind-Value="ViewModel.IsOrFilter">OR Filters Toggle (Uncheck for AND Filters)</Switch>
    </Div>
</Div>

<Div Flex="Flex.Column" Gap="Gap.Is2" Background="Background.Body" Margin="Margin.Is2.FromBottom">
    <Div Flex="Flex.Wrap.JustifyContent.Center.AlignContent.Center" Gap="Gap.Is2">
        @foreach (var attackType in ViewModel.AttackTypes)
        {
            <AttackTypeFilter @key="attackType" AttackType="attackType"/>
        }

        <Span>|</Span>

        @foreach (var attribute in ViewModel.Attributes)
        {
            <AttributeFilter @key="attribute" Attribute="attribute"/>
        }

        <Span>|</Span>

        <ExEnhancementFilter/>
    </Div>

    <Div Flex="Flex.Wrap.JustifyContent.Center.AlignContent.Center" Gap="Gap.Is2">
        <InitialRarityFilter Rarity="3"/>

        <Span>|</Span>

        <InitialRarityFilter Rarity="4"/>

        <Span>|</Span>

        <InitialRarityFilter Rarity="5"/>

        <Span>|</Span>

        <InitialRarityFilter Rarity="6"/>

        <Span>|</Span>

        <InitialRarityFilter Rarity="7"/>
    </Div>

    <Div Flex="Flex.Wrap.JustifyContent.Center.AlignContent.Center" Gap="Gap.Is2">
        @foreach (var tacticType in ViewModel.TacticTypes)
        {
            <TacticsTypeFilter @key="tacticType" TacticType="tacticType"/>
        }
    </Div>

    <Div Flex="Flex.Wrap.JustifyContent.Center.AlignContent.Center" Gap="Gap.Is2">
        @foreach (var expertise in ViewModel.BattleExpertises)
        {
            <ExpertiseFilter @key="expertise" Expertise="expertise"/>
        }
    </Div>
</Div>

<Div Flex="Flex.Wrap" Gap="Gap.Is2" Background="Background.Body" Margin="Margin.Is2.FromBottom">
    <Dropdown>
        <DropdownToggle Color="Color.Dark" Border="Border.White">Forces</DropdownToggle>
        <DropdownMenu MaxMenuHeight="50vh" Background="Background.Dark">
            @foreach (var forceGroup in ViewModel.Forces)
            {
                <DropdownHeader @key="forceGroup" TextColor="TextColor.White50">@forceGroup.Key</DropdownHeader>

                @foreach (var force in forceGroup.Items)
                {
                    <DropdownItem TextColor="TextColor.Light">
                        <ForceFilter @key="force" Force="force"/>
                    </DropdownItem>
                }

                <DropdownDivider/>
            }
        </DropdownMenu>
    </Dropdown>

    <Dropdown>
        <DropdownToggle Color="Color.Dark" Border="Border.White">Suited Facilities</DropdownToggle>
        <DropdownMenu MaxMenuHeight="50vh" Background="Background.Dark">
            @foreach (var buildingGroup in ViewModel.SuitedFacilities)
            {
                <DropdownHeader @key="buildingGroup" TextColor="TextColor.White50">@buildingGroup.Key</DropdownHeader>

                @foreach (var building in buildingGroup.Items)
                {
                    <DropdownItem TextColor="TextColor.Light">
                        <SuitedFacilityFilter @key="@($"{building.FieldBuilding.Name}_{building.Value}")"
                                              SuitedFacility="building"/>
                    </DropdownItem>
                }

                <DropdownDivider/>
            }
        </DropdownMenu>
    </Dropdown>
</Div>

<Div Flex="Flex.Wrap" Gap="Gap.Is2">
    @foreach (var filter in ViewModel.Filters)
    {
        if (filter.KeyType == typeof(AttackTypeFilter))
        {
            <AttackTypeFilter @key="filter.Key" AttackType="filter.Parameter as IAttackType" IsRemoveMode="true"/>
        }
        else if (filter.KeyType == typeof(AttributeFilter))
        {
            <AttributeFilter @key="filter.Key" Attribute="filter.Parameter as IAttribute" IsRemoveMode="true"/>
        }
        else if (filter.KeyType == typeof(ExEnhancementFilter))
        {
            <ExEnhancementFilter @key="filter.Key" IsRemoveMode="true"/>
        }
        else if (filter.KeyType == typeof(ExpertiseFilter))
        {
            <ExpertiseFilter @key="filter.Key" Expertise="filter.Parameter as BattleExpertise" IsRemoveMode="true"/>
        }
        else if (filter.KeyType == typeof(SuitedFacilityFilter))
        {
            <SuitedFacilityFilter @key="filter.Key" SuitedFacility="filter.Parameter as SuitedFacility"
                                 IsRemoveMode="true"/>
        }
        else if (filter.KeyType == typeof(ForceFilter))
        {
            <ForceFilter @key="filter.Key" Force="filter.Parameter as Force" IsRemoveMode="true"/>
        }
        else if (filter.KeyType == typeof(InitialRarityFilter))
        {
            <InitialRarityFilter @key="filter.Key" Rarity="(int) (filter.Parameter ?? 0)" IsRemoveMode="true"/>
        }
        else if (filter.KeyType == typeof(NameFilter))
        {
            <NameFilter @key="filter.Key" Search="filter.Parameter as SearchResult" IsRemoveMode="true"/>
        }
        else if (filter.KeyType == typeof(TacticsTypeFilter))
        {
            <TacticsTypeFilter @key="filter.Key" TacticType="filter.Parameter as TacticType" IsRemoveMode="true"/>
        }
    }
</Div>