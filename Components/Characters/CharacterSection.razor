@inherits ReactiveComponentBase<CharacterSectionViewModel>
@using System.Reactive.Disposables.Fluent
@using DynamicData.Binding
@using SlimeIMWiki.Services
@using ReactiveUI

@inject IServiceProvider ServiceProvider
@inject IJSInProcessRuntime JS
@inject ILogger<CharacterSection> Logger
@inject JsonDataModelService JsonDataModelService

@{ Debug.Assert(ViewModel != null, nameof(ViewModel) + " != null"); }

<Div Flex="Flex.Wrap.JustifyContent.Between" Gap="Gap.Is2.OnY" Margin="Margin.Is2.FromBottom">
    <Div Flex="Flex.Row">
        <Buttons Border="Border.White">
            <Button Size="Size.Small" Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2" Border="Border.RoundedStart"
                    Color="@(ViewModel.DisplayCategory == CharacterListDisplayCategory.Battle ? Color.Light : Color.Dark)"
                    Command="ViewModel.ChangeDisplayCategoryCommand"
                    CommandParameter="CharacterListDisplayCategory.Battle">
                <ImageProxy Source="image/character_types/icCharaTypePc.png" Width="Width.Em(1.5)"
                            Height="Height.Em(1.5)"/>
                <Text Display="Display.None.Block.OnTablet">Battle Units</Text>
            </Button>
            <Button Size="Size.Small" Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2" Border="Border.RoundedEnd"
                    Color="@(ViewModel.DisplayCategory == CharacterListDisplayCategory.Protection ? Color.Light : Color.Dark)"
                    Command="ViewModel.ChangeDisplayCategoryCommand"
                    CommandParameter="CharacterListDisplayCategory.Protection">
                <ImageProxy Source="image/character_types/icCharaTypeBless.png" Width="Width.Em(1.5)"
                            Height="Height.Em(1.5)"/>
                <Text Display="Display.None.Block.OnTablet">Protection Units</Text>
            </Button>
        </Buttons>
    </Div>

    <Div Flex="Flex.Row">
        <Buttons Border="Border.White">
            <Button Size="Size.Small" Color="Color.Dark" Border="Border.RoundedStart"
                    Command="ViewModel.ToggleDisplayOrderCommand">
                <Icon Name="@(ViewModel.IsOrderByDescending ? IconName.ChevronDown : IconName.ChevronUp)"/>
            </Button>
            <Button Size="Size.Small" Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2"
                    Color="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Release ? Color.Light : Color.Dark)"
                    Command="ViewModel.ChangeDisplayOrderCommand"
                    CommandParameter="CharacterListDisplayOrder.Release">
                <Icon Name="IconName.Clock"/>
                <Text Display="Display.None.Block.OnTablet">Release</Text>
            </Button>
            <Button Size="Size.Small" Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2"
                    Color="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Health ? Color.Light : Color.Dark)"
                    Command="ViewModel.ChangeDisplayOrderCommand"
                    CommandParameter="CharacterListDisplayOrder.Health">
                <ImageProxy Height="Height.Em(1.5)" Source="image/character_info/icHpShadow.png" Text="Hp"
                            Style="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Health ? "filter: invert(100%)" : "filter: invert(0%)")"/>
                <Text Display="Display.None.Block.OnTablet">Health</Text>
            </Button>
            <Button Size="Size.Small" Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2"
                    Color="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Attack ? Color.Light : Color.Dark)"
                    Command="ViewModel.ChangeDisplayOrderCommand"
                    CommandParameter="CharacterListDisplayOrder.Attack">
                <ImageProxy Height="Height.Em(1.5)" Source="image/character_info/icAtkShadow.png" Text="Atk"
                            Style="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Attack ? "filter: invert(100%)" : "filter: invert(0%)")"/>
                <Text Display="Display.None.Block.OnTablet">Attack</Text>
            </Button>
            <Button Size="Size.Small" Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2"
                    Color="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Defense ? Color.Light : Color.Dark)"
                    Command="ViewModel.ChangeDisplayOrderCommand"
                    CommandParameter="CharacterListDisplayOrder.Defense">
                <ImageProxy Height="Height.Em(1.5)" Source="image/character_info/icDefShadow.png" Text="Def"
                            Style="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Defense ? "filter: invert(100%)" : "filter: invert(0%)")"/>
                <Text Display="Display.None.Block.OnTablet">Defense</Text>
            </Button>
            <Button Size="Size.Small" Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2"
                    Color="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Rarity ? Color.Light : Color.Dark)"
                    Command="ViewModel.ChangeDisplayOrderCommand"
                    CommandParameter="CharacterListDisplayOrder.Rarity">
                <Icon Name="IconName.Star"/>
                <Text Display="Display.None.Block.OnTablet">Rarity</Text>
            </Button>
            <Button Size="Size.Small" Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2" Border="Border.RoundedEnd"
                    Color="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Name ? Color.Light : Color.Dark)"
                    Command="ViewModel.ChangeDisplayOrderCommand"
                    CommandParameter="CharacterListDisplayOrder.Name">
                <ImageProxy Height="Height.Em(1)" Source="image/character_info/icPopulation.png" Text="Population"
                            Style="@(ViewModel.DisplayOrder == CharacterListDisplayOrder.Name ? "filter: invert(100%)" : "filter: invert(0%)")"/>
                <Text Display="Display.None.Block.OnTablet">Name</Text>
            </Button>
        </Buttons>
    </Div>
</Div>

<Div Background="Background.Body" Position="Position.Relative"
     Style="height: calc(100vh - 56px - 4rem - 1.5rem); overflow-y: scroll"
     @onscroll="OnScroll" ElementId="UnitScrollContainer">

    <Div Style="@($"height: {_unitContainerHeight}px")">
        <Div Flex="Flex.Wrap" Gap="Gap.Is3.OnX.Is5.OnY" Padding="Padding.Is5.FromTop.Is3.FromBottom"
             Position="Position.Absolute"
             Style="@($"top: {_startIndex / _itemsPerRow * (_itemHeight + _itemHeightGap)}px")">
            @foreach (var unit in ViewModel.CharacterUnits.Skip(_startIndex).Take(_endIndex - _startIndex))
            {
                if (unit is BattleUnit battleUnit)
                {
                    <BattleUnitIcon @key="unit.Permalink" Unit="battleUnit" DisplayText="@ViewModel.DisplayText(unit)"/>
                }
                else if (unit is ProtectionUnit protectionUnit)
                {
                    <ProtectionUnitIcon @key="unit.Permalink" Unit="protectionUnit" DisplayText="@ViewModel.DisplayText(unit)"/>
                }
            }
        </Div>
    </Div>
</Div>

@code
{
    private IJSInProcessObjectReference? _module;

    private float _unitScrollContainerWidth;
    private float _unitScrollContainerHeight;
    private float _unitContainerHeight;
    private float _scrollPosition;

    private const int _itemWidth = 100;
    private const int _itemHeight = 100;
    private const int _itemWidthGap = 16;
    private const int _itemHeightGap = 48;
    private const int _overscanRowCount = 2;
    private int _itemsPerRow = 1;
    private int _visibleRowCount = 1;

    private int _overscanAboveRowCount;
    private int _overscanBelowRowCount;

    private int _startIndex;
    private int _endIndex = 1;

    protected override void OnInitialized()
    {
        ViewModel = ActivatorUtilities.CreateInstance<CharacterSectionViewModel>(ServiceProvider);

        this.WhenActivated(disposable =>
        {
            JsonDataModelService.RefreshData().DisposeWith(disposable);

#pragma warning disable CS8602 // Dereference of a possibly null reference.
            this.WhenAnyValue(section => section.ViewModel.CharacterUnits)
#pragma warning restore CS8602 // Dereference of a possibly null reference.
                .SwitchSelect(units => units.ObserveCollectionChanges())
                .Subscribe(_ => UpdateVisibleItems())
                .DisposeWith(disposable);
        });
        
        base.OnInitialized();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSInProcessObjectReference?>("import", "./Components/Characters/CharacterSection.razor.js");

            UpdateScrollContainer();
            UpdateVisibleItems();
        }

        _module?.InvokeVoid("setScrollPosition", "UnitScrollContainer", ViewModel?.ScrollPosition);

        await base.OnAfterRenderAsync(firstRender);
    }

    private void OnScroll()
    {
        UpdateScrollContainer();
        UpdateScrollPosition();
        UpdateVisibleItems();
    }

    private void UpdateScrollContainer()
    {
        if (_module is null) return;

        _unitScrollContainerWidth = _module.Invoke<float>("getElementWidth", "UnitScrollContainer");
        _unitScrollContainerHeight = _module.Invoke<float>("getElementHeight", "UnitScrollContainer");
        
        Logger.LogTrace("Unit Container Size: {width}, {height}", _unitScrollContainerWidth, _unitScrollContainerHeight);
    }

    private void UpdateScrollPosition()
    {
        if (_module is null) return;

        _scrollPosition = MathF.Max(0, _module.Invoke<float>("getScrollPosition", "UnitScrollContainer"));
        ViewModel?.ScrollPosition = _scrollPosition;

        Logger.LogTrace("Scroll Position: {position}", _scrollPosition);
    }

    private void UpdateVisibleItems()
    {
        if (_module is null) return;

        Debug.Assert(ViewModel != null, nameof(ViewModel) + " != null");

        _itemsPerRow = (int) Math.Floor(_unitScrollContainerWidth / (_itemWidth + _itemWidthGap));
        _visibleRowCount = (int) Math.Ceiling(_unitScrollContainerHeight / (_itemHeight + _itemHeightGap));

        _overscanAboveRowCount = Math.Clamp((int) MathF.Floor(_scrollPosition / (_itemHeight + _itemHeightGap)), 0, _overscanRowCount);
        _overscanBelowRowCount = _overscanRowCount;

        _startIndex = (int) MathF.Floor(_scrollPosition / (_itemHeight + _itemHeightGap)) * _itemsPerRow - _itemsPerRow * _overscanAboveRowCount;
        _endIndex = _startIndex + _itemsPerRow * (_overscanAboveRowCount + _visibleRowCount + _overscanBelowRowCount);
        _endIndex = Math.Min(_endIndex, ViewModel.CharacterUnits.Count);
        
        _unitContainerHeight = MathF.Ceiling((float) ViewModel.CharacterUnits.Count / _itemsPerRow) * (_itemHeight + _itemHeightGap);
        
        InvokeAsync(StateHasChanged);
        
        Logger.LogTrace("Item Per Row: {itemsPerRow}", _itemsPerRow);
        Logger.LogTrace("Overscan Above Row Count: {renderedRowCount}", _overscanAboveRowCount);
        Logger.LogTrace("Overscan Below Row Count: {renderedRowCount}", _overscanBelowRowCount);
        Logger.LogTrace("Unit Count: {count}", ViewModel.CharacterUnits.Count);
        Logger.LogTrace("Index: {start} / {end}", _startIndex, _endIndex);
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing)
        {
            _module?.Dispose();
        }
        
        base.Dispose(disposing);
    }
}
