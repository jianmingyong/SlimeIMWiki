@code
{
    [Parameter]
    [EditorRequired]
    public required ProtectionUnit Unit { get; set; }

    [Parameter]
    [EditorRequired]
    public required string DisplayText { get; set; }

    private string _firstIcon = string.Empty;
    private string _firstIconText = string.Empty;

    private string _secondIcon = string.Empty;
    private string _secondIconText = string.Empty;

    protected override void OnInitialized()
    {
        if (Unit.Forces is not null && Unit.Forces.Length > 0)
        {
            _firstIcon = Unit.Forces[0].Icon;
            _firstIconText = Unit.Forces[0].Name;

            if (Unit.Attributes is not null && Unit.Attributes.Length > 0)
            {
                _secondIcon = Unit.Attributes[0].Icon;
                _secondIconText = Unit.Attributes[0].Name;
            }
            else if (Unit.AttackType is not null)
            {
                _secondIcon = Unit.AttackType.Icon;
                _secondIconText = Unit.AttackType.Name;
            }
        }
        else if (Unit.Attributes is not null && Unit.Attributes.Length > 0)
        {
            _firstIcon = Unit.Attributes[0].Icon;
            _firstIconText = Unit.Attributes[0].Name;

            if (Unit.Attributes.Length >= 2)
            {
                _secondIcon = Unit.Attributes[1].Icon;
                _secondIconText = Unit.Attributes[1].Name;
            }
            else if (Unit.AttackType is not null)
            {
                _secondIcon = Unit.AttackType.Icon;
                _secondIconText = Unit.AttackType.Name;
            }
        }
        else if (Unit.AttackType is not null)
        {
            _firstIcon = Unit.AttackType.Icon;
            _firstIconText = Unit.AttackType.Name;
        }

        base.OnInitialized();
    }
}

<Link To="@($"characters/{Unit.Permalink}")"
      Position="Position.Relative"
      Width="Width.Px(100)" Height="Height.Px(100)"
      Style="user-select: none">
<Div Position="Position.Absolute.Start.Is0.Top.Is0"
     Padding="Padding.Is1.OnX"
     TextSize="TextSize.ExtraSmall" TextColor="TextColor.Body"
     Background="Background.Body"
     Style="z-index:4; transform: translateY(-100%)">
    @DisplayText
</Div>

<Div Position="Position.Absolute.End.Is0.Top.Is0" Width="Width.Is25" Flex="Flex.Column" Style="z-index: 3">
    <ImageProxy Width="Width.Is100" Height="Height.Is100" Source="@_firstIcon" Text="@_firstIconText"/>
    <ImageProxy Width="Width.Is100" Height="Height.Is100" Source="@_secondIcon" Text="@_secondIconText"/>
</Div>

@switch (Unit.InitialRarity)
{
    case 3:
    {
        <ImageProxy Position="Position.Absolute.Start.Is0.Bottom.Is0" Width="Width.Is33"
                    Source="image/rarity/starCharaL3A.png"
                    Style="z-index: 3"/>

        <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                    Source="image/rarity/frameBlessM3.png"
                    Style="z-index: 2"/>

        <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                    Source="image/rarity/baseBlessM3.png"
                    Style="z-index: 0"/>

        break;
    }

    case 4:
    {
        <ImageProxy Position="Position.Absolute.Start.Is0.Bottom.Is0" Width="Width.Is33"
                    Source="image/rarity/starCharaL4A.png"
                    Style="z-index: 3"/>

        <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                    Source="image/rarity/frameBlessM4.png"
                    Style="z-index: 2"/>

        <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                    Source="image/rarity/baseBlessM4.png"
                    Style="z-index: 0"/>

        break;
    }

    case 5:
    {
        @if (Unit.IsEx)
        {
            <ImageProxy Position="Position.Absolute.Start.Is0.Bottom.Is0" Width="Width.Is33"
                        Source="image/rarity/starCharaL6UA.png"
                        Style="z-index: 3"/>

            <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                        Source="image/rarity/frameBlessM6u.png"
                        Style="z-index: 2"/>

            <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                        Source="image/rarity/baseBlessM6u.png"
                        Style="z-index: 0"/>
        }
        else if (Unit.IsAttributeUnbound)
        {
            <ImageProxy Position="Position.Absolute.Start.Is0.Bottom.Is0" Width="Width.Is33"
                        Source="image/rarity/starCharaL6UPA.png"
                        Style="z-index: 3"/>

            <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                        Source="image/rarity/frameBlessM6up.png"
                        Style="z-index: 2"/>

            <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                        Source="image/rarity/baseBlessM6up.png"
                        Style="z-index: 0"/>
        }
        else
        {
            <ImageProxy Position="Position.Absolute.Start.Is0.Bottom.Is0" Width="Width.Is33"
                        Source="image/rarity/starCharaL5A.png"
                        Style="z-index: 3"/>

            <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                        Source="image/rarity/frameBlessM5.png"
                        Style="z-index: 2"/>

            <ImageProxy Position="Position.Absolute.Start.Is0.Top.Is0" Width="Width.Is100"
                        Source="image/rarity/baseBlessM5.png"
                        Style="z-index: 0"/>
        }

        break;
    }
}

<ImageProxy Position="Position.Absolute.Start.Is50.Translate.MiddleX"
            Width="Width.Px(99)" Height="Height.Px(99)"
            Source="@Unit.Icon"
            Text="@Unit.Permalink"
            Style="z-index: 1"/>
</Link>