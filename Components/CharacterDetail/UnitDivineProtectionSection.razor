@code
{
    [Parameter]
    [EditorRequired]
    public required ProtectionUnit Unit { get; set; }
}

<Div Background="Background.Body">
    <Div Flex="Flex.Grow.Is1" Padding="Padding.Is2" Border="Border.Is1.OnBottom">
        <Div TextAlignment="TextAlignment.Center" TextWeight="TextWeight.Bold">DIVINE PROTECTION</Div>
    </Div>

    <Div Flex="Flex.Column" Background="Background.Body" Padding="Padding.Is2" Gap="Gap.Is2">
        <Div Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2">
            <Div Width="Width.Em(4)" Height="Height.Em(4)">
                <ImageProxy Source="image/character_info/blessConfirmIcon.png" Width="Width.Is100" Text="Icon"/>
            </Div>
            <Div>
                <Div TextWeight="TextWeight.Bold">
                    @(string.IsNullOrEmpty(Unit.DivineProtectionName) ? "???" : Unit.DivineProtectionName)
                </Div>
                <Div TextSize="TextSize.ExtraSmall" Style="color: yellow">Lv. Max</Div>
            </Div>
        </Div>

        <Div>
            <EffectStyler Text="@Unit.DivineProtectionEffectMax"/>
        </Div>

        <Div Flex="Flex.Grow.Is1" Padding="Padding.Is2" Border="Border.Is1.OnTop.Is1.OnBottom">
            <Div TextAlignment="TextAlignment.Center" TextWeight="TextWeight.Bold"
                 TextSize="TextSize.ExtraSmall">Supporting Divine Protection</Div>
        </Div>

        <Div>
            <EffectStyler Text="@(string.IsNullOrEmpty(Unit.SupportDivineProtectionEffectMax)
                                    ? "???"
                                    : Unit.SupportDivineProtectionEffectMax)"/>
        </Div>
    </Div>
</Div>