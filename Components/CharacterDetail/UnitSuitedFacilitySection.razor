@code
{
    [Parameter]
    [EditorRequired]
    public required ICharacterUnit Unit { get; set; }
}

<Div Background="Background.Body">
    <Div Flex="Flex.Grow.Is1" Padding="Padding.Is2" Border="Border.Is1.OnBottom">
        <Div TextAlignment="TextAlignment.Center" TextWeight="TextWeight.Bold">SUITED FACILITIES</Div>
    </Div>

    <Div Padding="Padding.Is2" Flex="Flex.Column" Gap="Gap.Is2">
        @if (Unit is BattleUnit battleUnit)
        {
            if (battleUnit.SuitedFacilities.Length == 0)
            {
                <Div>No Suited Facilities have been assigned.</Div>
            }
            else
            {
                foreach (var suitedFacility in battleUnit.SuitedFacilities)
                {
                    <Div Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2">
                        <ImageProxy Width="Width.Em(1.5)" Height="Height.Em(1.5)"
                                    Source="@suitedFacility.FieldBuilding.Icon"
                                    Text="Icon"/>
                        <Div Flex="Flex.Grow.Is1">@suitedFacility.FieldBuilding.Name</Div>
                        <Div>@(suitedFacility.Value.ToString("D"))%</Div>
                    </Div>
                }
            }
        }
        else if (Unit is ProtectionUnit protectionUnit)
        {
            if (protectionUnit.SuitedFacilities.Length == 0)
            {
                <Div>No Suited Facilities have been assigned.</Div>
            }
            else
            {
                foreach (var suitedFacility in protectionUnit.SuitedFacilities)
                {
                    <Div Flex="Flex.Row.AlignItems.Center" Gap="Gap.Is2">
                        <ImageProxy Width="Width.Em(1.5)" Height="Height.Em(1.5)"
                                    Source="@suitedFacility.FieldBuilding.Icon"
                                    Text="Icon"/>
                        <Div Flex="Flex.Grow.Is1">@suitedFacility.FieldBuilding.Name</Div>
                        <Div>@(suitedFacility.Value.ToString("D"))%</Div>
                    </Div>
                }
            }
        }
    </Div>
</Div>